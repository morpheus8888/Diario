// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model Entry {
  id        String   @id @default(cuid())
  userId    String   @index
  title     String?
  content   Json
  mood      String?
  tags      String[] @default([]) @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DevUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  sessions DevSession[]
}

model DevSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime?

  user DevUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
